# Telegram
BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_API_ROOT=http://localhost:8081
ALLOWED_USER_IDS=123456,789012
ALLOWED_CHAT_IDS=-1001234567890
UPLOAD_CHAT_ID=-1001234567890

# qBittorrent
QB_HOST=localhost
QB_PORT=8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Paths
DOWNLOAD_DIR=/downloads
PROCESSING_DIR=/processing
QUEUE_DIR=/data/queue

# Library (optional)
# Set to enable "入庫" button — copies completed files to this path
LIBRARY_PATH=

# Split
SPLIT_TARGET_SIZE_MB=1950

# Cleanup
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_INTERVAL_MINUTES=5

# VPN (optional)
# Place your WireGuard config at ./data/wireguard/wg0.conf
# Then start with: docker compose -f docker-compose.yml -f docker-compose.vpn.yml up -d

# Stream Server
# Set STREAM_HOST to enable direct download links proxied from Telegram
# Example: http://your-server-ip:8082
# STREAM_SECRET must be the same value for both bot and stream containers
STREAM_HOST=
STREAM_SECRET=
